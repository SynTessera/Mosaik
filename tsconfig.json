{
  "compilerOptions": {
    "rootDirs": ["lib"],
    "outDir": "dist",
    "target": "ES2022",
    "typeRoots": ["./node_modules/@types", "./lib"],
    "lib": ["ES2023", "DOM", "DOM.Iterable", "ESNext"],
    "module": "NodeNext",
    "jsx": "react-jsx",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "declaration": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./lib/*"]
    }
  },
  "files": ["./lib/svg.d.ts"],
  "exclude": ["node_modules/@syntessera/tesseract/lib/tesseract.d.ts"],
  "include": ["./lib/**/*.*", "./lib/svg.d.ts", "./lib/global.d.ts"],
  "tsc-alias": {
    "verbose": false,
    "resolveFullPaths": true
  }
}
